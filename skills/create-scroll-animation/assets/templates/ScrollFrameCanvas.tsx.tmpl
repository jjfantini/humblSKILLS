// =============================================================================
// ScrollFrameCanvas — template file
//
// Generated by create-scroll-animation v0.1.0. When substituting, replace:
//   {{COMPONENT_NAME}}          → the component export name (default: ScrollFrameCanvas)
//   {{FRAME_COUNT}}             → integer (e.g. 100)
//   {{FRAME_URL_PATTERN}}       → e.g. "/frames/frame_{index}.webp"
//   {{FRAME_DIGITS}}            → integer (e.g. 4) — zero-pad width for {index}
//   {{SCROLL_HEIGHT_VH}}        → integer (e.g. 350)
//   {{CRITICAL_PRELOAD_COUNT}}  → integer (e.g. 10)
//   {{BRAND_BG}}                → hex color (e.g. "#000000"); only used if loader included
//   {{BRAND_ACCENT}}            → hex color (e.g. "#ffffff"); only used if loader included
//
// Conditional blocks — when the flag is FALSE, DELETE the whole block
// (everything from the "// ==== BEGIN <flag>" line to the matching
// "// ==== END <flag>" line inclusive):
//   INCLUDE_REDUCED_MOTION_FALLBACK
//   INCLUDE_LOADER_UI
//
// After substitution, this file should be a drop-in .tsx with zero template
// artifacts and no `{{...}}` remaining.
// =============================================================================

'use client';

import { useEffect, useRef, useState } from 'react';
import { useScroll, useTransform, useMotionValueEvent } from 'framer-motion';

type Props = {
  /** Override total frame count if rendering a subset. Defaults to generated constant. */
  frameCount?: number;
  /**
   * Override URL pattern. Use `{index}` as the placeholder for the zero-padded frame index.
   * Defaults to the constant baked in at generation time.
   */
  frameUrlPattern?: string;
  /** Override zero-pad width. Default: {{FRAME_DIGITS}}. */
  frameDigits?: number;
  /** Override section height in vh. Default: {{SCROLL_HEIGHT_VH}}. */
  scrollHeightVh?: number;
  /** Override critical preload count. Default: {{CRITICAL_PRELOAD_COUNT}}. */
  criticalPreloadCount?: number;
};

const DEFAULT_FRAME_COUNT = {{FRAME_COUNT}};
const DEFAULT_FRAME_URL_PATTERN = '{{FRAME_URL_PATTERN}}';
const DEFAULT_FRAME_DIGITS = {{FRAME_DIGITS}};
const DEFAULT_SCROLL_HEIGHT_VH = {{SCROLL_HEIGHT_VH}};
const DEFAULT_CRITICAL_PRELOAD_COUNT = {{CRITICAL_PRELOAD_COUNT}};

export function {{COMPONENT_NAME}}({
  frameCount = DEFAULT_FRAME_COUNT,
  frameUrlPattern = DEFAULT_FRAME_URL_PATTERN,
  frameDigits = DEFAULT_FRAME_DIGITS,
  scrollHeightVh = DEFAULT_SCROLL_HEIGHT_VH,
  criticalPreloadCount = DEFAULT_CRITICAL_PRELOAD_COUNT,
}: Props) {
  // ==== BEGIN INCLUDE_REDUCED_MOTION_FALLBACK
  const [prefersReducedMotion, setPrefersReducedMotion] = useState(false);

  useEffect(() => {
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    setPrefersReducedMotion(mq.matches);
    const onChange = (e: MediaQueryListEvent) => setPrefersReducedMotion(e.matches);
    mq.addEventListener('change', onChange);
    return () => mq.removeEventListener('change', onChange);
  }, []);

  if (prefersReducedMotion) {
    const firstFrameUrl = frameUrlPattern.replace(
      '{index}',
      String(1).padStart(frameDigits, '0'),
    );
    return (
      <section style={{ height: '100vh', position: 'relative' }}>
        <img
          src={firstFrameUrl}
          alt=""
          aria-hidden="true"
          style={{ width: '100%', height: '100%', objectFit: 'cover', display: 'block' }}
        />
      </section>
    );
  }
  // ==== END INCLUDE_REDUCED_MOTION_FALLBACK

  const containerRef = useRef<HTMLDivElement | null>(null);
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const framesRef = useRef<Map<number, HTMLImageElement>>(new Map());
  const lastDrawn = useRef<number>(-1);

  // ==== BEGIN INCLUDE_LOADER_UI
  const [progress, setProgress] = useState(0);
  const [ready, setReady] = useState(false);

  useEffect(() => {
    if (ready) return;
    const prev = document.documentElement.style.overflow;
    document.documentElement.style.overflow = 'hidden';
    return () => {
      document.documentElement.style.overflow = prev;
    };
  }, [ready]);
  // ==== END INCLUDE_LOADER_UI

  const { scrollYProgress } = useScroll({
    target: containerRef,
    offset: ['start start', 'end end'],
  });
  const frameIndex = useTransform(scrollYProgress, [0, 1], [0, frameCount - 1]);

  useEffect(() => {
    const sizeCanvas = () => {
      const canvas = canvasRef.current;
      if (!canvas) return;
      const dpr = window.devicePixelRatio || 1;
      const w = window.innerWidth;
      const h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = `${w}px`;
      canvas.style.height = `${h}px`;
      canvas.getContext('2d')?.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (lastDrawn.current >= 0) drawFrame(lastDrawn.current);
    };
    sizeCanvas();
    window.addEventListener('resize', sizeCanvas);
    return () => window.removeEventListener('resize', sizeCanvas);

  }, []);

  useEffect(() => {
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const concurrency = isMobile ? 3 : 6;
    const critical = Math.min(criticalPreloadCount, frameCount);

    const frameUrl = (idx: number) =>
      frameUrlPattern.replace('{index}', String(idx + 1).padStart(frameDigits, '0'));

    const loadOne = async (idx: number) => {
      const img = new Image();
      img.decoding = 'async';
      (img as HTMLImageElement & { fetchPriority?: string }).fetchPriority =
        idx < critical ? 'high' : 'auto';
      img.src = frameUrl(idx);
      try {
        await img.decode();
      } catch {
        /* decode can reject on decode errors; swallow */
      }
      framesRef.current.set(idx, img);
      // ==== BEGIN INCLUDE_LOADER_UI
      setProgress((p) => Math.max(p, (framesRef.current.size) / frameCount));
      // ==== END INCLUDE_LOADER_UI
    };

    let cancelled = false;

    (async () => {
      // Phase 1: critical batch, fully awaited.
      await Promise.all(Array.from({ length: critical }, (_, i) => loadOne(i)));
      if (cancelled) return;
      drawFrame(0);
      // ==== BEGIN INCLUDE_LOADER_UI
      setReady(true);
      // ==== END INCLUDE_LOADER_UI

      // Phase 2: streamed rest.
      const queue: number[] = [];
      for (let i = critical; i < frameCount; i++) queue.push(i);
      const workers = Array.from({ length: concurrency }, async () => {
        while (queue.length > 0 && !cancelled) {
          const next = queue.shift();
          if (next === undefined) return;
          await loadOne(next);
        }
      });
      await Promise.all(workers);
    })();

    return () => {
      cancelled = true;
    };

  }, [frameCount, frameUrlPattern, frameDigits, criticalPreloadCount]);

  useMotionValueEvent(frameIndex, 'change', (latest) => {
    const idx = Math.round(latest);
    if (idx === lastDrawn.current) return;
    lastDrawn.current = idx;
    drawFrame(idx);
  });

  function drawFrame(idx: number) {
    const canvas = canvasRef.current;
    const ctx = canvas?.getContext('2d');
    const img = framesRef.current.get(idx);
    if (!canvas || !ctx || !img) return;

    const dpr = window.devicePixelRatio || 1;
    const cw = canvas.width / dpr;
    const ch = canvas.height / dpr;
    const iw = img.naturalWidth;
    const ih = img.naturalHeight;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    ctx.clearRect(0, 0, cw, ch);

    const scale = isMobile
      ? Math.min(cw / iw, ch / ih) * 1.2
      : Math.max(cw / iw, ch / ih);
    const dw = iw * scale;
    const dh = ih * scale;
    ctx.drawImage(img, (cw - dw) / 2, (ch - dh) / 2, dw, dh);
  }

  return (
    <>
      <section
        ref={containerRef}
        style={{ height: `${scrollHeightVh}vh`, position: 'relative' }}
      >
        <div style={{ position: 'sticky', top: 0, height: '100vh', overflow: 'hidden' }}>
          <canvas ref={canvasRef} style={{ display: 'block' }} />
        </div>
      </section>

      {/* ==== BEGIN INCLUDE_LOADER_UI */}
      {!ready && (
        <div
          aria-busy="true"
          aria-label="Loading scroll animation"
          style={{
            position: 'fixed',
            inset: 0,
            zIndex: 50,
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            backgroundColor: '{{BRAND_BG}}',
            transition: 'opacity 400ms ease',
            opacity: ready ? 0 : 1,
            pointerEvents: ready ? 'none' : 'auto',
          }}
        >
          <div style={{ width: 240, textAlign: 'center', color: '#fff' }}>
            <div style={{ fontSize: 14, opacity: 0.6, marginBottom: 12 }}>Loading</div>
            <div
              style={{
                height: 2,
                background: 'rgba(255,255,255,0.12)',
                borderRadius: 1,
                overflow: 'hidden',
              }}
            >
              <div
                style={{
                  height: '100%',
                  width: `${Math.round(progress * 100)}%`,
                  background: '{{BRAND_ACCENT}}',
                  transition: 'width 150ms ease',
                }}
              />
            </div>
            <div style={{ fontSize: 11, opacity: 0.4, marginTop: 10 }}>
              {Math.round(progress * 100)}%
            </div>
          </div>
        </div>
      )}
      {/* ==== END INCLUDE_LOADER_UI */}
    </>
  );
}
