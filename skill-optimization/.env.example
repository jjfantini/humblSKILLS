# pindex / SkillOpt credentials. Copy to `.env` and fill in, then:
#   set -a; source .env; set +a

# ── Default backend: Claude (claude_chat) ──────────────────────────────────
# SkillOpt's claude_chat backend drives the LOCAL `claude` CLI as a subprocess.
# It uses whatever auth your `claude` CLI already has, so usually you only need
# the CLI installed and logged in (`claude` then `/login`), or this key:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Optional: pin the Claude models SkillOpt asks the CLI to use.
# OPTIMIZER_DEPLOYMENT=claude-sonnet-4-6
# TARGET_DEPLOYMENT=claude-sonnet-4-6

# ── Fast / cheap smoke backend: OpenAI (openai_chat, no nested CLI) ─────────
# SkillOpt's openai_chat backend uses the Azure-OpenAI client, but with
# auth_mode=openai_compatible it talks to plain OpenAI. Set:
# AZURE_OPENAI_AUTH_MODE=openai_compatible
# AZURE_OPENAI_ENDPOINT=https://api.openai.com/v1
# AZURE_OPENAI_API_KEY=sk-...      # your OpenAI key

# ── Azure OpenAI (production openai_chat) ──────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_API_KEY=
