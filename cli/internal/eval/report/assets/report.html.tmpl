<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>humblskills eval · {{.SkillName}} · iter {{.Iteration}}</title>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
<style>
  body { font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, sans-serif;
         margin: 0; padding: 24px; background: #0c0d12; color: #e6e7ec; max-width: 1280px; margin-left: auto; margin-right: auto; }
  h1 { font-size: 22px; margin: 0 0 6px; font-weight: 600; letter-spacing: -0.02em; }
  h2 { font-size: 13px; margin: 28px 0 10px; text-transform: uppercase;
       letter-spacing: 0.08em; color: #8d8f98; font-weight: 600; }
  .meta { color: #8d8f98; margin-bottom: 14px; font-size: 13px; line-height: 1.6; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0 20px; }
  .chip { background: #1a1c26; border: 1px solid #2e3140; border-radius: 999px; padding: 4px 12px; font-size: 12px; color: #c4c6d0; }
  .exec { background: linear-gradient(145deg, #15171f 0%, #12131a 100%); border: 1px solid #2a2d38; border-radius: 8px; padding: 16px 18px; margin-bottom: 20px; }
  .exec h2 { margin: 0 0 10px; font-size: 12px; }
  .exec ul { margin: 0; padding-left: 1.2em; color: #d8d9e0; }
  .exec li { margin: 6px 0; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
  .card { background: #13141b; border: 1px solid #24262f; border-radius: 8px;
          padding: 10px 12px 4px; min-height: 300px; }
  .card h3 { margin: 0 0 8px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: #8d8f98; font-weight: 600; }
  .empty { color: #8d8f98; padding: 24px; text-align: center;
           font-size: 13px; font-style: italic; }
  table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  th, td { padding: 8px 12px; text-align: left; border-bottom: 1px solid #24262f; }
  th { color: #8d8f98; font-weight: 500; text-transform: uppercase;
       font-size: 11px; letter-spacing: 0.06em; }
  th.num { text-align: right; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .pos { color: #4ade80; } .neg { color: #f87171; }
  .footer { margin-top: 28px; color: #8d8f98; font-size: 12px; line-height: 1.5; }
  code { background: #24262f; padding: 1px 5px; border-radius: 3px;
         font: 12px/1 ui-monospace, SFMono-Regular, monospace; }
  .note { font-size: 12px; color: #8d8f98; margin-top: 8px; }
</style>
</head>
<body>

<h1>{{.SkillName}} · iteration {{.Iteration}}</h1>
<div class="meta">Runner <code>{{.Runner}}</code> · Generated by humblskills eval. Pass rate and tokens are aggregated per session index (longitudinal runs compound in session order for <code>smart_skill</code>).</div>

{{if .ScenarioIDs}}
<div class="chips">
  {{range .ScenarioIDs}}<span class="chip">{{.}}</span>{{end}}
</div>
{{end}}

<div class="exec">
  <h2>What to read first</h2>
  <ul id="narrative"></ul>
  <p class="note" id="narrative_fallback" style="display:none;">No narrative bullets were generated. Open <code>report.json</code> for full trajectory and benchmark objects.</p>
</div>

<h2>Charts</h2>
<div class="grid">
  <div class="card"><h3>Pass rate</h3><div id="pass_rate" style="width:100%;height:280px;"></div></div>
  <div class="card"><h3>Tokens (mean per session)</h3><div id="tokens" style="width:100%;height:280px;"></div></div>
  <div class="card"><h3>Pass^k (all assertions pass this session)</h3><div id="pass_at_k" style="width:100%;height:280px;"></div></div>
  <div class="card"><h3>Brain: patterns.md entries (smart_skill)</h3><div id="patterns" style="width:100%;height:280px;"></div></div>
</div>
<p class="note">The patterns series tracks cumulative entries in <code>references/patterns.md</code> after each session (flat and no_skill are typically flat at zero). Rising values indicate the brain is accumulating lessons across sessions.</p>

<h2>Derived metrics</h2>
<div class="card">
<table id="derived">
  <thead><tr><th>arm</th><th class="num">learning velocity</th><th class="num">token ratio (last/first)</th></tr></thead>
  <tbody></tbody>
</table>
</div>

<h2>Longitudinal: first vs last session (per scenario)</h2>
<div class="card">
<table id="learning_spans">
  <thead><tr><th>scenario</th><th>arm</th><th class="num">first pass</th><th class="num">last pass</th><th class="num">delta</th><th>sessions</th></tr></thead>
  <tbody></tbody>
</table>
</div>

<h2>Cross-section (mean over all runs)</h2>
<div class="card">
<table id="cross_section">
  <thead><tr><th>arm</th><th class="num">pass_rate</th><th class="num">tokens</th><th class="num">time s</th><th class="num">cost $</th></tr></thead>
  <tbody></tbody>
</table>
</div>

<h2>Deltas (smart_skill baseline comparisons)</h2>
<div class="card">
<table id="deltas">
  <thead><tr><th>pair</th><th class="num">delta pass_rate</th><th class="num">delta tokens</th><th class="num">delta time s</th><th class="num">delta cost $</th></tr></thead>
  <tbody></tbody>
</table>
</div>

<div class="footer">
  Arms: {{range .Arms}}<code>{{.}}</code> &middot; {{end}}
  <br>humblSKILLS longitudinal evals: <code>smart_skill</code> restores prior brain state between sessions so <code>patterns.md</code> and related files can compound. Compare cross-section deltas and longitudinal tables to argue skill + brain vs flat instructions vs no skill.
</div>

<script>
(function() {
  const data = {{.DataJSON}};

  const narrEl = document.getElementById("narrative");
  const narrFallback = document.getElementById("narrative_fallback");
  if (data.narrative && data.narrative.length) {
    for (const line of data.narrative) {
      const li = document.createElement("li");
      li.textContent = line;
      narrEl.appendChild(li);
    }
  } else {
    narrFallback.style.display = "block";
  }

  const hasSeries = data && data.series && Object.keys(data.series).length > 0;
  if (!hasSeries) {
    const empty = '<div class="empty">No trajectory series. Runner may have failed, or no sessions were graded. See transcripts under the iteration directory.</div>';
    for (const id of ["pass_rate", "tokens", "pass_at_k", "patterns"]) {
      document.getElementById(id).innerHTML = empty;
    }
  }

  const layout = {
    paper_bgcolor: "#13141b", plot_bgcolor: "#13141b",
    font: { family: "Inter, -apple-system, sans-serif", color: "#e6e7ec", size: 11 },
    margin: { l: 48, r: 12, t: 32, b: 44 },
    showlegend: true, legend: { orientation: "h", y: -0.18 },
    xaxis: { title: "session index", gridcolor: "#24262f", zerolinecolor: "#24262f" },
    yaxis: { gridcolor: "#24262f", zerolinecolor: "#24262f" }
  };
  const palette = { smart_skill: "#a78bfa", flat_skill: "#60a5fa", no_skill: "#94a3b8" };
  function tracesFor(field) {
    return Object.keys(data.series || {}).sort().map(arm => ({
      x: data.series[arm].sessions,
      y: data.series[arm][field],
      name: arm,
      mode: "lines+markers",
      line: { color: palette[arm] || "#eab308", width: 2 },
      marker: { size: 6 }
    }));
  }
  if (hasSeries && typeof Plotly !== "undefined") {
    Plotly.newPlot("pass_rate", tracesFor("pass_rate"),
      Object.assign({}, layout, { title: "" }),
      { displayModeBar: false, responsive: true });
    Plotly.newPlot("tokens", tracesFor("tokens"),
      Object.assign({}, layout, { title: "" }),
      { displayModeBar: false, responsive: true });
    Plotly.newPlot("pass_at_k", tracesFor("pass_at_k"),
      Object.assign({}, layout, { title: "" }),
      { displayModeBar: false, responsive: true });
    const patTraces = Object.keys(data.series || {}).sort().map(arm => ({
      x: data.series[arm].sessions,
      y: (data.series[arm].patterns_entries || []).map(Number),
      name: arm,
      mode: "lines+markers",
      line: { color: palette[arm] || "#eab308", width: 2 },
      marker: { size: 6 }
    }));
    Plotly.newPlot("patterns", patTraces,
      Object.assign({}, layout, { yaxis: Object.assign({}, layout.yaxis, { title: "entries" }), title: "" }),
      { displayModeBar: false, responsive: true });
  }

  const dtbody = document.querySelector("#derived tbody");
  const dkeys = Object.keys(data.derived || {}).sort();
  if (dkeys.length === 0) {
    dtbody.innerHTML = '<tr><td colspan="3" class="empty">no derived metrics (need at least two sessions per arm)</td></tr>';
  }
  for (const arm of dkeys) {
    const d = data.derived[arm];
    const tr = document.createElement("tr");
    const ratio = (d.token_decay !== undefined && d.token_decay !== null) ? Number(d.token_decay).toFixed(3) : "-";
    tr.innerHTML = `<td><code>${arm}</code></td>
      <td class="num">${d.learning_velocity !== undefined ? Number(d.learning_velocity).toFixed(4) : "-"}</td>
      <td class="num">${ratio}</td>`;
    dtbody.appendChild(tr);
  }

  const ltbody = document.querySelector("#learning_spans tbody");
  const spans = data.learning_spans || [];
  if (spans.length === 0) {
    ltbody.innerHTML = '<tr><td colspan="6" class="empty">no multi-session scenarios in this run</td></tr>';
  }
  for (const s of spans) {
    const tr = document.createElement("tr");
    const cls = s.delta_pass >= 0 ? "pos" : "neg";
    tr.innerHTML = `<td><code>${s.scenario}</code></td>
      <td><code>${s.arm}</code></td>
      <td class="num">${Number(s.first_pass_mean).toFixed(3)}</td>
      <td class="num">${Number(s.last_pass_mean).toFixed(3)}</td>
      <td class="num ${cls}">${s.delta_pass >= 0 ? "+" : ""}${Number(s.delta_pass).toFixed(3)}</td>
      <td>${s.session_min}-${s.session_max}</td>`;
    ltbody.appendChild(tr);
  }

  const tbody = document.querySelector("#cross_section tbody");
  const arms = Object.keys(data.summary || {}).sort();
  if (arms.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" class="empty">no cross-section data</td></tr>';
  }
  for (const arm of arms) {
    const s = data.summary[arm];
    const tr = document.createElement("tr");
    tr.innerHTML = `<td><code>${arm}</code></td>
      <td class="num">${s.pass_rate.mean.toFixed(3)}</td>
      <td class="num">${Math.round(s.tokens.mean)}</td>
      <td class="num">${s.time_seconds.mean.toFixed(1)}</td>
      <td class="num">${(s.cost_usd.mean||0).toFixed(3)}</td>`;
    tbody.appendChild(tr);
  }
  const dltbody = document.querySelector("#deltas tbody");
  const deltaKeys = Object.keys(data.delta || {}).sort();
  if (deltaKeys.length === 0) {
    dltbody.innerHTML = '<tr><td colspan="5" class="empty">no deltas (need smart_skill and at least one other arm)</td></tr>';
  }
  for (const pair of deltaKeys) {
    const d = data.delta[pair];
    const cls = v => v >= 0 ? "pos" : "neg";
    const tr = document.createElement("tr");
    tr.innerHTML = `<td><code>${pair}</code></td>
      <td class="num ${cls(d.pass_rate)}">${d.pass_rate >= 0 ? "+" : ""}${d.pass_rate.toFixed(3)}</td>
      <td class="num ${cls(-d.tokens)}">${d.tokens >= 0 ? "+" : ""}${Math.round(d.tokens)}</td>
      <td class="num ${cls(-d.time_seconds)}">${d.time_seconds >= 0 ? "+" : ""}${d.time_seconds.toFixed(1)}</td>
      <td class="num ${cls(-d.cost_usd)}">${d.cost_usd >= 0 ? "+" : ""}${d.cost_usd.toFixed(3)}</td>`;
    dltbody.appendChild(tr);
  }
})();
</script>
</body>
</html>
